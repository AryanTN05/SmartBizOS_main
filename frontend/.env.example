# Frontend env (Vite picks these up at build time).
#
# In dev: leave VITE_API_BASE_URL empty so requests go to the same origin
# (Vite proxies /api -> :8000 via vite.config.js).
#
# In production: point this at the deployed backend (e.g. Cloud Run URL).
# CORS_ORIGINS in the backend must include this frontend's origin.
VITE_API_BASE_URL=
