# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST/DBNAME

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080,https://www.zerotoprod.tech,https://zerotoprod.tech

# ── Tenant ────────────────────────────────────────────────────────────────────
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your-random-32-char-secret-here

# Admin users seeded on startup. Generate password_hash with:
# python -c "from passlib.context import CryptContext; c=CryptContext(schemes=['bcrypt']); print(c.hash('yourpassword'))"
ADMIN_USERS_JSON=[{"email":"admin@yourcompany.com","name":"Admin","password_hash":"your-bcrypt-hash-here"}]
# ── API Keys ──────────────────────────────────────
GOOGLE_API_KEY=your-google-ai-studio-key
FIRECRAWL_API_KEY=your-firecrawl-key

# ── Database ──────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:pass@host/dbname?ssl=require

# ── App Defaults ──────────────────────────────────
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001

# ── Email (Resend) ───────────────────────────────
# Sender of automation emails. Falls back to onboarding@resend.dev (Resend's
# free verified sender) if unset.
RESEND_API_KEY=
RESEND_FROM=

# ── Automations ──────────────────────────────────
# Scheduler tick interval (seconds). Lower = more responsive, higher CPU.
AUTOMATION_TICK_SECONDS=3
# Wait between send_day0 and the synthetic open. Default is 3 days; for dev
# set to 8 so a run reaches its terminal state during a session.
# AUTOMATION_WAIT_SECONDS=8

# ── IMAP reply detection ─────────────────────────
# Fernet key for encrypting per-tenant IMAP passwords at rest. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Without this, the IMAP poller noops at startup.
IMAP_ENCRYPTION_KEY=
IMAP_POLL_SECONDS=600
